# Copy to .env.local for local dev. On GitHub, set these as repository secrets
# (Settings > Secrets and variables > Actions) so the deploy workflow can inject them.
# Both are safe to expose in the client bundle — RLS is the real wall.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
